# ══════════════════════════════════════════════════════════════
#  NEXUS-NODE Backend — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env — it is gitignored.
# ══════════════════════════════════════════════════════════════

# ── LLM ──────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...                      # from console.groq.com
GOOGLE_API_KEY=AIza...                    # from aistudio.google.com

# ── MCP tokens ───────────────────────────────────────────────
GITHUB_MCP_TOKEN=ghp_...                  # GitHub PAT with repo:read scope
SLACK_MCP_BOT_TOKEN=xoxb-...              # Slack bot token (chat:write, channels:read)
SALESFORCE_MCP_CLIENT_ID=...              # Salesforce connected app client_id
SALESFORCE_MCP_CLIENT_SECRET=...          # Salesforce connected app client_secret
SALESFORCE_MCP_INSTANCE_URL=https://yourorg.my.salesforce.com

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=eyJ...               # service_role key — NEVER expose to browser
SUPABASE_ANON_KEY=eyJ...                  # anon key — safe for frontend

# ── Auth / JWT (RS256) ────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Then paste the PEM content as a single-line string with \n for newlines
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ALGORITHM=RS256
JWT_EXPIRE_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── App behaviour ─────────────────────────────────────────────
LOG_LEVEL=DEBUG                           # DEBUG | INFO | WARNING | ERROR | CRITICAL
MAX_ITERATIONS=10
HITL_TIMEOUT_SECONDS=600
ENVIRONMENT=development                   # development | staging | production
